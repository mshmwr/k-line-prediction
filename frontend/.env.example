# Copy to .env.local and fill in your actual values.
# .env.local is gitignored — never commit real values.

# GA4 Measurement ID (format: G-XXXXXXXXXX)
# Leave empty to disable GA4 tracking entirely.
VITE_GA_MEASUREMENT_ID=

# Backend API base URL (DEV ONLY — optional).
# In production (K-049 Phase 2b onward), /api/** is served same-origin via
# Firebase Hosting rewrite to Cloud Run. VITE_API_BASE_URL may be left unset
# and the frontend falls back to relative "/api/..." paths.
# For local dev: vite.config.ts already proxies /api -> localhost:8000, so
# this variable is also optional locally. Kept here for reference.
VITE_API_BASE_URL=
