{
  "name": "k-line-prediction",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18 <21",
    "npm": ">=9"
  },
  "scripts": {
    "pretest": "node ./scripts/patch-vitest-node16.mjs",
    "dev": "vite",
    "prebuild": "SRC=$(cd .. && pwd)/docs/ai-collab-protocols.md && test -f \"$SRC\" || { echo \"prebuild error: missing $SRC\"; exit 1; } && mkdir -p public/docs && cp \"$SRC\" public/docs/",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "node ./scripts/patch-vitest-node16.mjs && vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "axios": "^1.7.2",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.32.3",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.4.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
